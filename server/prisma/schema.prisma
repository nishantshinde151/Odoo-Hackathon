datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  role      String    // "ADMIN" | "EMPLOYEE"
  status    String    @default("ACTIVE") // "ACTIVE" | "ARCHIVED"
  sessions  Session[]
}

model Session {
  id             Int       @id @default(autoincrement())
  userId         Int
  user           User      @relation(fields: [userId], references: [id])
  openingTime    DateTime  @default(now())
  closingTime    DateTime?
  openingBalance Decimal   @db.Decimal(10, 2)
  closingAmount  Decimal?  @db.Decimal(10, 2)
  status         String    @default("OPEN") // "OPEN" | "CLOSED"
  orders         Order[]
}

model Customer {
  id     Int     @id @default(autoincrement())
  name   String
  email  String?
  phone  String?
  orders Order[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  color    String    @default("#795548")
  products Product[]
}

model Product {
  id             Int         @id @default(autoincrement())
  name           String
  categoryId     Int
  category       Category    @relation(fields: [categoryId], references: [id])
  price          Decimal     @db.Decimal(10, 2)
  taxPercentage  Decimal     @db.Decimal(5, 2) @default(5.00)
  uom            String      @default("Unit")
  description    String?
  active         Boolean     @default(true)
  orderItems     OrderItem[]
}

model Floor {
  id     Int     @id @default(autoincrement())
  name   String
  tables Table[]
}

model Table {
  id          Int     @id @default(autoincrement())
  floorId     Int
  floor       Floor   @relation(fields: [floorId], references: [id])
  tableNumber String
  seatsCount  Int     @default(4)
  active      Boolean @default(true)
  orders      Order[]
}

model Order {
  id           Int           @id @default(autoincrement())
  sessionId    Int
  session      Session       @relation(fields: [sessionId], references: [id])
  tableId      Int
  table        Table         @relation(fields: [tableId], references: [id])
  customerId   Int?
  customer     Customer?     @relation(fields: [customerId], references: [id])
  orderNumber  String        @unique
  status       String        @default("DRAFT") // "DRAFT" | "KITCHEN" | "PREPARING" | "COMPLETED" | "PAID" | "CANCELLED"
  subtotal     Decimal       @db.Decimal(10, 2)
  tax          Decimal       @db.Decimal(10, 2)
  discount     Decimal       @db.Decimal(10, 2) @default(0.00)
  grandTotal   Decimal       @db.Decimal(10, 2)
  createdAt    DateTime      @default(now())
  orderItems   OrderItem[]
  payments     Payment[]
  orderCoupons OrderCoupon[]
}

model OrderItem {
  id             Int     @id @default(autoincrement())
  orderId        Int
  order          Order   @relation(fields: [orderId], references: [id])
  productId      Int
  product        Product @relation(fields: [productId], references: [id])
  quantity       Int
  unitPrice      Decimal @db.Decimal(10, 2)
  taxAmount      Decimal @db.Decimal(10, 2)
  discountAmount Decimal @db.Decimal(10, 2) @default(0.00)
  total          Decimal @db.Decimal(10, 2)
}

model Payment {
  id                   Int      @id @default(autoincrement())
  orderId              Int
  order                Order    @relation(fields: [orderId], references: [id])
  method               String   // "CASH" | "CARD" | "UPI"
  amount               Decimal  @db.Decimal(10, 2)
  transactionReference String?
  paymentDate          DateTime @default(now())
}

model Coupon {
  id             Int           @id @default(autoincrement())
  code           String        @unique
  discountType   String        // "PERCENTAGE" | "FIXED"
  discountValue  Decimal       @db.Decimal(10, 2)
  expirationDate DateTime
  active         Boolean       @default(true)
  orderCoupons   OrderCoupon[]
}

model OrderCoupon {
  id       Int    @id @default(autoincrement())
  orderId  Int
  order    Order  @relation(fields: [orderId], references: [id])
  couponId Int
  coupon   Coupon @relation(fields: [couponId], references: [id])
}

model Promotion {
  id            Int      @id @default(autoincrement())
  name          String
  type          String   // "PRODUCT" | "ORDER"
  triggerQty    Int?
  triggerValue  Decimal? @db.Decimal(10, 2)
  discountValue Decimal  @db.Decimal(10, 2)
  active        Boolean  @default(true)
}
